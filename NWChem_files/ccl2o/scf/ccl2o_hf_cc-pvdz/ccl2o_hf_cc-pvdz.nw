start phosgene

memory 1000 mb

geometry units angstroms
  O1     0.000     0.000     1.648
  C2     0.000     0.000     0.492
  Cl3    0.000     1.448    -0.475
  Cl4    0.000    -1.448    -0.475
end

basis
  O  library cc-pvdz
  C  library cc-pvdz
  Cl library cc-pvdz
end

scf
  singlet
  rhf
  thresh 1e-8
  maxiter 100
  print low
end

task scf



