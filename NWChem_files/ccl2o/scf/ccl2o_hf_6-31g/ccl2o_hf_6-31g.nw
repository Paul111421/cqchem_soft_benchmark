start phosgene

memory 1000 mb

geometry units angstroms
  O1     0.000     0.000     1.680
  C2     0.000     0.000     0.505
  Cl3    0.000     1.496    -0.484
  Cl4    0.000    -1.496    -0.484
end

basis
  O  library 6-31g
  C  library 6-31g
  Cl library 6-31g
end

scf
  singlet
  rhf
  thresh 1e-8
  maxiter 100
  print low
end

task scf



