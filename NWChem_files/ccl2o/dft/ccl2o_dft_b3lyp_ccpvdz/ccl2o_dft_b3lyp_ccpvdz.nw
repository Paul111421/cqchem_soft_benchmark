start phosgene

memory 1000 mb

geometry units angstroms
  O1     0.000     0.000     1.687
  C2     0.000     0.000     0.508
  Cl3    0.000     1.464    -0.487
  Cl4    0.000    -1.464    -0.487
end

basis
  O  library cc-pvdz
  C  library cc-pvdz
  Cl library cc-pvdz
end

dft
  mult 1 
  xc b3lyp
  maxiter 100
  print low
end

task dft

