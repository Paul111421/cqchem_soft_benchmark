start phosgene

memory 1000 mb

geometry units angstroms
  O1     0.000     0.000     1.677
  C2     0.000     0.000     0.504
  Cl3    0.000     1.457    -0.483
  Cl4    0.000    -1.457    -0.483
end

basis
  O  library cc-pVTZ
  C  library cc-pVTZ
  Cl library cc-pVTZ
end

dft
  mult 1 
  xc b3lyp
  maxiter 100
  print low
end

task dft

