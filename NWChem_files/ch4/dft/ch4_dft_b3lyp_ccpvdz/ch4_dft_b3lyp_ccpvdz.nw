start methane

memory 1000 mb

geometry units angstroms
  C1     0.000     0.000     0.000
  H1     0.635     0.635     0.635
  H2    -0.635    -0.635     0.635
  H3    -0.635     0.635    -0.635
  H4     0.635    -0.635    -0.635 
end

basis
  C library cc-pvdz
  H library cc-pvdz
end

dft
  mult 1 
  xc b3lyp
  maxiter 100
  print low
end

task dft

