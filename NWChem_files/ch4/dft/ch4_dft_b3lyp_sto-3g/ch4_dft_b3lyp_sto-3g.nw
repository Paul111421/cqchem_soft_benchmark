start methane

memory 1000 mb

geometry units angstroms
  C1     0.000     0.000     0.000
  H1     0.633     0.633     0.633
  H2    -0.633    -0.633     0.633
  H3    -0.633     0.633    -0.633
  H4     0.633    -0.633    -0.633 
end

basis
  C library sto-3g
  H library sto-3g
end

dft
  mult 1 
  xc b3lyp
  maxiter 100
  print low
end

task dft

