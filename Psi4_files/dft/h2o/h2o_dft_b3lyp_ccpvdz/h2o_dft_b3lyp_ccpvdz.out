#! Sample DFT/cc-pVDZ H2O computation

memory 600 mb

molecule h2o {
  O  0.000  0.000  0.121
  H  0.000  0.756 -0.484
  H  0.000 -0.756 -0.484
  units angstrom
}


set basis cc-pVDZ
energy('scf', dft_functional = 'b3lyp')

