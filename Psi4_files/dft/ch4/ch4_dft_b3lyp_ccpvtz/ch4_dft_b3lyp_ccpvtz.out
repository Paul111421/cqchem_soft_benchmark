#! Sample DFT/cc-pVTZ CH4 computation

memory 600 mb

molecule ch4 {
  C1  0.000  0.000  0.000
  H2  0.628  0.628  0.628
  H3 -0.628 -0.628  0.628
  H4 -0.628  0.628 -0.628
  H5  0.628 -0.628 -0.628  
  units angstrom
}


set basis cc-pVTZ
energy('scf',dft_functional = 'b3lyp')

