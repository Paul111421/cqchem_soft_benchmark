#! Sample DFT/cc-pVDZ CH4 computation

memory 600 mb

molecule ch4 {
  C1  0.000  0.000  0.000
  H2  0.635  0.635  0.635
  H3 -0.635 -0.635  0.635
  H4 -0.635  0.635 -0.635
  H5  0.635 -0.635 -0.635  
  units angstrom
}


set basis cc-pVDZ
energy('scf',dft_functional = 'b3lyp')

